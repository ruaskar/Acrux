# Canonical PyApp build recipe for keymd.
# Sourced by packaging/build_binary.sh and .github/workflows/binary.yml.
# PYAPP_PROJECT_PATH (the embedded keymd wheel) is set by the build script.
# One variable per line, no inline comments — this file is `source`d as-is.
# Reference: https://ofek.dev/pyapp/latest/config/
#
# EXEC_MODULE       run `python -m keymd` (keymd's existing entry point)
# PROJECT_FEATURES  install keymd[all]  (proxy + JS/TS + PDF/DOCX + watcher)
# PYTHON_VERSION    3.12 — every keymd dependency ships a cp312 wheel
# DISTRIBUTION_EMBED embed CPython in the binary → no first-run Python download
PYAPP_EXEC_MODULE=keymd
PYAPP_PROJECT_FEATURES=all
PYAPP_PYTHON_VERSION=3.12
PYAPP_DISTRIBUTION_EMBED=1
