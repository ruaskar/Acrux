# Binary fixtures must never get line-ending conversion (autocrlf would corrupt them).
*.pdf  binary
*.docx binary

# Shell scripts + the PyApp env recipe run on Linux/macOS CI — force LF so a
# Windows checkout (autocrlf) never commits CRLF that would break `bash` there.
*.sh   text eol=lf
*.env  text eol=lf
# GitHub Actions workflows run their `run:` blocks under bash — CRLF would break them.
*.yml  text eol=lf
*.yaml text eol=lf
# PowerShell installer is Windows-only — pin CRLF so its EOL is deterministic too.
*.ps1  text eol=crlf
